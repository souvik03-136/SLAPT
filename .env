# ── Ports ────────────────────────────────────────────────────────────────────
NGINX_PORT=80
WEB_PORT=3000
PARSER_PORT=3001

# ── Service URLs ─────────────────────────────────────────────────────────────
# Used by the web server-side (SvelteKit) to reach the parser inside Docker.
# In local dev (no Docker), change this to http://localhost:3001
PARSER_URL=http://parser:3001

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production